{
  "name": "flow",
  "version": "0.12.2",
  "description": "buildflow gated build harness: idea to real done-evidence through honest gates (web|cli|library|skill), with a durable harness layer and agent orchestration (ck: + bmad + Codex second engine + Antigravity/Gemini-3 third engine). Portable across Claude Code (/flow), Codex CLI ($flow), and Antigravity (agy CLI / IDE).",
  "type": "skill",
  "plugin": ".claude-plugin/plugin.json",
  "command": "/flow (Claude Code) | $flow (Codex CLI)",
  "entry": "skills/flow/SKILL.md",
  "runner": "skills/flow/runner/flow.sh",
  "runner_windows": "skills/flow/runner/flow.cmd (PowerShell/cmd/Codex launcher -> Git Bash; avoids WSL path failures)",
  "runtime": {
    "bash": "required (gate runner; Git Bash on Windows)",
    "python": "optional (durable harness layer; stdlib sqlite3, no pip install)",
    "cargo": "optional (Rust harness power-path via FLOW_HARNESS_BACKEND=rust)"
  },
  "install": {
    "global": "~/.claude/skills/flow (+ ~/.codex/skills/flow and ~/.agents/skills/flow when those harnesses exist)",
    "global_targets": { "claude": "~/.claude/skills/flow", "codex": "~/.codex/skills/flow", "agents": "~/.agents/skills/flow" },
    "project": ".claude/skills/flow",
    "scripts": ["install.sh", "install.ps1"],
    "invoke": { "claude_code": "/flow", "codex_cli": "$flow" }
  },
  "components": {
    "engine": "skills/flow/runner/flow.sh",
    "skill": "skills/flow/SKILL.md",
    "templates": "skills/flow/_templates/",
    "law": "skills/flow/law/",
    "references": "skills/flow/references/",
    "durable_layer": "skills/flow/harness/",
    "playbooks": "skills/flow/playbooks/"
  },
  "tests": ["tests/test_flow_runner.sh", "tests/test_flow_harness.sh", "tests/test_flow_scenarios.sh", "tests/test_flow_project_types.sh", "tests/test_flow_gate_wording.sh", "tests/test_flow_coverage_gaps.sh", "tests/test_flow_concurrency_lock.sh", "tests/test_flow_recall.sh", "tests/test_flow_gate_capture.sh", "tests/test_flow_propose_audit.sh", "tests/test_flow_contract.sh", "tests/test_flow_tokens.sh", "tests/test_flow_coherence_kb.sh", "tests/test_flow_assess.sh", "tests/test_flow_codex_integration.sh", "tests/test_flow_consistency.sh", "tests/test_flow_accessed_count.sh", "tests/test_flow_constitution.sh", "tests/test_flow_antigravity_integration.sh"],
  "provenance": {
    "methodology": "ai20k-build-phase/buildflow (Tony, arealisticdreamer.com)",
    "harness": "repository-harness",
    "agents_and_packaging": "claudekit-engineer",
    "method_and_review": "BMAD-METHOD",
    "principles": "research-report-agent-orchestration-2026.md"
  }
}
