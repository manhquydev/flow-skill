# Force LF on scripts so the bash runner and python harness work after a Windows clone.
# CRLF in a shebang/script breaks `bash` with "\r: command not found".
*.sh   text eol=lf
*.py   text eol=lf
*.json text eol=lf
# Batch launcher must be CRLF — some cmd.exe builds mis-parse LF-only .cmd files.
*.cmd  text eol=crlf
# Leave markdown/other text to the platform default.
