# runtime artifacts (created when /flow runs in a project)
.flow/
*.db
*.db-wal
*.db-shm

# Claude Code agent memory (session-scoped, do not track)
.claude/

# python
__pycache__/
*.pyc

# os
.DS_Store
Thumbs.db

# /flow run-state (generated; safe to ignore)
MODE
PROJECT_TYPE
.flow/

# transient test scratch dirs (usage-log dwell cross-project fixtures)
tests/.dwell_xproj_*

# eval card-fixture ancestor-adoption marker dirs (deliberately empty; must ship
# despite the .flow/ ignore rules above, so the fixture root looks self-contained)
!skills/flow/eval/fixtures/*/.flow/
!skills/flow/eval/fixtures/*/.flow/.gitkeep
